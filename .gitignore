# ══════════════════════════════════════════════════════
# TradeBot AI — .gitignore
# ══════════════════════════════════════════════════════

# ── CRÍTICO — nunca subir ──────────────────────────────
.env
.env.*
*.env
!.env.example

# ── Base de datos ──────────────────────────────────────
*.db
*.sqlite
*.sqlite3
instance/
liq_events.db

# ── Base de conocimiento (grande y privada) ────────────
base_conocimiento/
chroma_db/

# ── Archivos de datos y caché en tiempo de ejecución ──
*.csv
*.pkl
*.pickle
edge_stats_cache.json
hmm_model.pkl

# ── Carpetas internas (no van al repo) ────────────────
document/

# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
venv/
env/
.venv/

# ── Logs ──────────────────────────────────────────────
*.log
logs/
tradebot_errors.log

# ── Node ──────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── OS ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────
.vscode/
.idea/
.claude/
*.swp
*.swo

# ── Temporales ────────────────────────────────────────
*.tmp
*.bak
temp/
tmp/
